  <Properties>
    <blockGridGroupTour>
      <Value><![CDATA[{
  "contentData": [
    {
      "contentTypeKey": "0708fc2f-92f1-4efc-a9d1-a755f66e6845",
      "key": "de67822c-5c55-45f2-b086-e3c1801dc29e",
      "udi": null,
      "values": []
    },
    {
      "contentTypeKey": "f170b29c-338f-4ab8-a5c4-f72c90826f69",
      "key": "808f04ca-8c8c-42f4-9818-d17a2ddae7b8",
      "udi": null,
      "values": []
    },
    {
      "contentTypeKey": "1e6ac523-7122-4994-9f51-7ca67065222a",
      "key": "5bcce114-9563-4ddf-a515-8b642c514edd",
      "udi": null,
      "values": []
    },
    {
      "contentTypeKey": "c345e5ce-768f-47e0-968a-e7859dbe0b07",
      "key": "79fad482-040f-4ea5-a9ef-69287a38d49b",
      "udi": null,
      "values": []
    },
    {
      "contentTypeKey": "365fd365-6ec4-4fbb-9434-1df366aa77f8",
      "key": "497d2c00-5ccd-4cf0-b899-7b8c15dd7fe1",
      "udi": null,
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Suggested Itinerary"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Ch3\u003EDay 1 \u2013 Kenmare\u003C/h3\u003E\n\u003Cp\u003EScheduled flight to Cork from your preferred airport \u2013 transfer with our guide in our private executive coach to the 3* Kenmare Bay Hotel in Kenmare.\u003C/p\u003E\n\u003Ch3\u003EDay 2 \u2013 Muckross House \u0026amp; dinner and traditional Irish music\u003C/h3\u003E\n\u003Cp\u003EMorning at leisure in Killarney and you may choose to take a ride on Killarney\u2019s famous horse-drawn Jaunting Cars \u2013 Muckross House was built for Henry Arthur Herbert and his wife, the water colourist Mary Balfour Herbert and is the fourth house that successive generations of the Herbert family have occupied over a period of almost two hundred years \u2013 tonight we have an evening out for dinner with traditional Irish music and entertainment.\u003C/p\u003E\n\u003Ch3\u003EDay 3 \u2013 The Ring of Kerry\u003C/h3\u003E\n\u003Cp\u003ETour with a local guide of the spectacularly beautiful coastline of the Ring of Kerry starts in the village of Kenmare and continues to Molls Gap for the most fantastic view, Killorglin, Caherciveen and Glenbeigh.\u003C/p\u003E\n\u003Ch3\u003EDay 4 \u2013 Glengariff, boat trip to Garnish Island \u0026amp; Beara Peninsular\u003C/h3\u003E\n\u003Cp\u003EMorning at leisure in Glengariff, one of Ireland\u0026#39;s most beautiful villages \u2013 an included boat trip to Garnish Island includes entrance to explore the scenic gardens followed by free time at leisure for lunch \u2013 with views of some of Ireland\u2019s most staggering mountain, lake and coastal scenery, the tour of the Beara Peninsula passes numerous prehistoric stones and tombs.\u003C/p\u003E\n\u003Ch3\u003EDay 5 \u2013 Kinsale \u0026amp; Cobh and the Queenstown Story Visitors Centre\u003C/h3\u003E\n\u003Cp\u003EOriginally a medieval fishing port and widely renowned as the gourmet capital of Ireland, Kinsale is one of the most picturesque, popular and historic towns on the south west coast \u2013 flight times permitting, at Cobh and the Queenstown Story Visitors Centre we discover one of the most important maritime naval bases in 19th century Europe that also served as the main Irish emigration centres to North America and Australia and was the last port of call for the ill-fated Titanic \u2013 transfer to Cork Airport for our flight back home.\u003C/p\u003E\n"
          }
        }
      ]
    },
    {
      "contentTypeKey": "34e5aa3b-db10-40a1-893d-79e98cd3f2f4",
      "key": "091bd29d-3762-4d61-a511-c160f97084fd",
      "udi": null,
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Features"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cul\u003E\n\u003Cli\u003E\u003Cp\u003EHalf board accommodation\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003EAll excursions \u0026amp; guided tours included\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003EProfessional local guide in Ireland\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003EScheduled flights to Cork\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003EExecutive coach throughout\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003EOne free place per 10 paying passengers\u003C/p\u003E\n\u003C/li\u003E\n\u003C/ul\u003E\n"
          }
        }
      ]
    },
    {
      "contentTypeKey": "1d09b5af-b95a-4af5-b8f2-323db029e817",
      "key": "48d5a071-91e4-4a86-86a9-b86865b2cc2b",
      "udi": null,
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Accommodation"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EWe stay four nights at the 4* Bridgewood Manor on the outskirts of Chatham (\u003Ca target=\u0022\u0022 data-router-slot=\u0022disabled\u0022 href=\u0022http://www.bridgewoodmanorhotel.com\u0022 type=\u0022external\u0022\u003Ewww.bridgewoodmanorhotel.com\u003C/a\u003E). Ideally located near to the motorways to gain easy access to the places visited in our itinerary, the hotel boasts a restaurant, bar, indoor swimming pool, sauna, steam room and a gymnasium. All of our allocated Standard Rooms are ensuite and feature television, hair dryer, and tea \u0026amp; coffee making facilities. A set 3 course dinner without drinks is included in our hotel on the first night. A choice 3 course dinner without drinks is included in our hotel on the remaining three nights of our tour.\u003C/p\u003E"
          }
        }
      ]
    },
    {
      "contentTypeKey": "2d9b0603-29ef-423a-8d3e-d9c039d3d7b1",
      "key": "dc1d7e56-31c7-4a7f-b861-218aba0112fe",
      "udi": null,
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sights"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "What we will see"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cul\u003E\n\u003Cli\u003E\u003Cp\u003EKenmare\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003EMuckross House\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003EDinner \u0026amp; traditional Irish music\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003ERing of Kerry - Kenmare, Molls Gap, Killorglin, Caherciveen \u0026amp; Glenbeigh\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003EBeautiful village of Glengariff\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003EBoat trip to Garnish Island\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003ETour of the Beara Peninsular\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003EKinsale\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003ECobh \u0026amp; the Queenstown Story Visitors Centre\u003C/p\u003E\n\u003C/li\u003E\n\u003C/ul\u003E\n"
          }
        }
      ]
    }
