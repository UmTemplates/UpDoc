    },
    {
      "contentTypeKey": "1e6ac523-7122-4994-9f51-7ca67065222a",
      "key": "c5214365-236f-42fb-99f2-cfe18a0014c0",
      "udi": null,
      "values": []
    },
    {
      "contentTypeKey": "c4b3a613-0d2c-4470-8d06-f7efea52d6e0",
      "key": "7e60025f-a601-4016-9bc2-af0a9ae81afb",
      "udi": null,
      "values": [
        {
          "alias": "featurePropertyNavigationInPageItems",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            "16d7f42b-3804-4ae0-a266-577ae247410c",
            "d501770b-c124-4652-920e-6dc7c298bed9",
            "cd5f9a55-504c-4966-99e4-93b0dcfb9ab5",
            "75626739-0584-4bfa-bfd4-66471ce1da5c"
          ]
        }
      ]
    },
    {
      "contentTypeKey": "365fd365-6ec4-4fbb-9434-1df366aa77f8",
      "key": "16d7f42b-3804-4ae0-a266-577ae247410c",
      "udi": null,
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Itinerary"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Ch3\u003EDay 1 \u2013 Chianciano Terme\u003C/h3\u003E\n\u003Cp\u003EScheduled flight to Italy from your preferred airport \u2013 transfer with our tour manager in our private executive coach to the 3* Hotel Villa Ricci in Chianciano Terme in Tuscany \u2013 dinner in the hotel.\u003C/p\u003E\n\u003Ch3\u003EDay 2 \u2013 Abbey of Monte Oliveto Maggiore, Pienza \u0026amp; Church of Madonna Di San Biagio\u003C/h3\u003E\n\u003Cp\u003EMorning guided tour of Abbey of Monte Oliveto Maggiore with one of the monks (voluntary donation) to see the magnificent 41 frescoes of the Life of St Benedict by Signorelli and Sodoma \u2013 explore the enchanting town of Pienza with time to walk along the walls to enjoy the wonderful views \u2013 the Church of Madonna Di San Biagio at Montepulciano dates back to 1518 and is one of the most important church buildings of the Renaissance period \u2013 dinner in the hotel.\u003C/p\u003E\n\u003Ch3\u003EDay 3 \u2013 Basilica of St Francis of Assisi, Perugia \u0026amp; Galleria Nazionale dell\u2019 Umbria\u003C/h3\u003E\n\u003Cp\u003EGuided tour of the Basilica of St Francis of Assisi and its wonderful frescoes by Giotto, Simone Martini and Lorenzetti \u2013 stop at the medieval town of Perugia to visit the Galleria Nazionale dell\u2019 Umbria, the centre for Umbrian art.\u003C/p\u003E\n\u003Ch3\u003EDay 4 \u2013 Siena \u0026amp; San Gimignano\u003C/h3\u003E\n\u003Cp\u003ESpend the morning in Siena \u2013 a guided tour of the Opera del Duomo with the 13th century Rose Window and the Duccio di Buoninsegna\u2019s 1308 altar piece dedicated to the Virgin Mary \u2013 free time to visit sights such as the Campo where the Palio horse race is run every year and the Piccolomini Library in the Duomo \u2013 travel into the Chianti wine growing region to visit San Gimignano with its cathedral housing the \u2018Poor Man\u2019s Bible\u2019 and the 13 defensive Medieval towers giving it the name \u2018the Small Manhattan\u2019.\u003C/p\u003E\n\u003Ch3\u003EDay 5 \u2013 Florence \u0026amp; the Uffizi\u003C/h3\u003E\n\u003Cp\u003EFull day in Florence, the capital of Renaissance art \u2013 pre-booked entry into the Uffizi Gallery, one of the world\u2019s finest art galleries, with time at leisure to enjoy the magnificent Renaissance masterpieces including works by Giotto, Masaccio, Paolo Ucello, Sandro Botticelli, Leonardo da Vinci, Michelangelo, Titian and Caravaggio \u2013 free time to visit Michelangelo\u2019s \u2018David\u2019 at the Accademia, the Ponte Vecchio, the magnificent Duomo, the Pitti Palace or Boboli Gardens \u2013 farewell dinner in hotel.\u003C/p\u003E\n\u003Ch3\u003EDay 6 \u2013 Pisa or Orvieto\u003C/h3\u003E\n\u003Cp\u003EDepending on the location of your preferred airport, visit the Leaning Tower of Pisa (Torre Pandente) which started to tilt even before the third storey was finished in 1274 or a morning guided tour of the charming Etruscan town of Orvieto \u2013 transfer to the airport for our scheduled flight back home.\u003C/p\u003E\n"
          }
        }
      ]
    },
    {
      "contentTypeKey": "34e5aa3b-db10-40a1-893d-79e98cd3f2f4",
      "key": "d501770b-c124-4652-920e-6dc7c298bed9",
      "udi": null,
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Features"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cul\u003E\n\u003Cli\u003E\u003Cp\u003EAll excursions \u0026amp; guided tours included\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003E3 dinners included\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003EProfessional tour manager\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003EScheduled flights to Italy\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003EExecutive coach in Italy\u003C/p\u003E\n\u003C/li\u003E\n\u003Cli\u003E\u003Cp\u003EOne free place per 10 paying passengers\u003C/p\u003E\n\u003C/li\u003E\n\u003C/ul\u003E\n"
          }
        }
      ]
    },
    {
      "contentTypeKey": "1d09b5af-b95a-4af5-b8f2-323db029e817",
      "key": "cd5f9a55-504c-4966-99e4-93b0dcfb9ab5",
      "udi": null,
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Accommodation"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EFive nights in the 3* Hotel Villa Ricci in Chianciano Terme in the heart of Tuscany. Dinner is included at the hotel on Days 1, 2 and 5 and the remaining nights are on bed and breakfast basis. All rooms are en suite and the hotel has a bar, restaurant and indoor pool.\u003C/p\u003E\n"
          }
        }
      ]
    },
    {
